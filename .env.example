DATABASE_URL="postgresql://postgres:postgres@localhost:5432/togetherly"
AUTH_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
# Required when any OAuth provider is enabled (Google, Microsoft).
# Generate one with: openssl rand -base64 32
# Encrypts access_token / refresh_token / id_token in the Account table.
# Rotating this key invalidates every linked OAuth account — users re-link.
OAUTH_TOKEN_ENCRYPTION_KEY=""
FILE_STORAGE_ROOT="./storage"
# Required to enable the scheduled source-refresh endpoint at
# /api/internal/refresh-sources. Generate one with: openssl rand -base64 32
# Cron service hits the endpoint with Authorization: Bearer <secret>.
# On Vercel deployments, prefer `CRON_SECRET` — Vercel auto-sets it
# when cron jobs are enabled (see vercel.json). For local dev or
# non-Vercel deployments, either env var works.
SCHEDULER_SECRET=""
# Optional — enables LLM-assisted classification (EXT-010) and the
# natural-language search front-door on /windows (MAT-008). Provision
# from console.anthropic.com. Product no-ops these features gracefully
# when unset, so local dev / CI without the key still works.
# Cost: ~$0.01 per source refresh THAT PRODUCES AMBIGUOUS CANDIDATES
# (most refreshes don't, because the candidate set is stable between
# runs), ~$0.002 per NL search button-press. Realistic monthly spend
# at 25-50 families: $5-15. Provision a $50/month budget alert as a
# safety net. See docs/LAUNCH_CHECKLIST.md §5 for full math.
ANTHROPIC_API_KEY=""
