DATABASE_URL="postgresql://postgres:postgres@localhost:5432/togetherly"
AUTH_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
# Required when any OAuth provider is enabled (Google, Microsoft).
# Generate one with: openssl rand -base64 32
# Encrypts access_token / refresh_token / id_token in the Account table.
# Rotating this key invalidates every linked OAuth account — users re-link.
OAUTH_TOKEN_ENCRYPTION_KEY=""
FILE_STORAGE_ROOT="./storage"
# Required to enable the scheduled source-refresh endpoint at
# /api/internal/refresh-sources. Generate one with: openssl rand -base64 32
# Cron service hits the endpoint with Authorization: Bearer <secret>.
# On Vercel deployments, prefer `CRON_SECRET` — Vercel auto-sets it
# when cron jobs are enabled (see vercel.json). For local dev or
# non-Vercel deployments, either env var works.
SCHEDULER_SECRET=""
# REQUIRED for HTML and PDF source ingestion. The heuristic HTML/PDF
# extractors were removed 2026-05-17 (see docs/DECISIONS.md). Without
# this key, adding a URL or PDF source produces a Failed refresh
# status with HtmlExtractionUnavailableError / PdfExtractionUnavailableError.
# ICS, Google Calendar, and Outlook Calendar ingestion do NOT depend on
# this key — those paths use provider APIs that return structured data.
# Also required for the natural-language search front-door on /windows.
# Provision at https://console.anthropic.com.
# Cost: ~$0.03-0.05 per HTML/PDF refresh call. With content-hash
# short-circuit (planned follow-up): ~$5-15/month at 25-50 families.
# Without short-circuit: ~$150/month worst case. Provision a $50-200/month
# budget alert. See docs/LAUNCH_CHECKLIST.md §5 for full math.
# CI uses a placeholder value because tests mock the SDK.
ANTHROPIC_API_KEY=""
